; ===========================================
; QwenASR 长音频识别 配置文件
; 流程: 切分音频 → 逐段 QwenASR 识别 → 合并结果
; ===========================================

[api]
; 阿里云百炼 API Key (优先使用环境变量 DASHSCOPE_API_KEY)
api_key = sk-xxxxx
; 地域: cn(北京) / intl(新加坡)
region = cn

[qwen]
; 模型名称
model = qwen3-asr-flash-2026-02-10
; 语言代码 (留空自动识别): zh / en / ja / yue 等
language = zh
; 是否启用 ITN 逆文本标准化
enable_itn = false

[split]
; 切分大小 (MB), base64 编码后约 4/3 倍, QwenASR 限制 ≤10MB, 建议 3-4MB
max_size_mb = 6.0
; 是否保留切分后的中间 WAV 文件 (true=保留 / false=删除)
keep_chunks = false
; 是否启用多线程 (true=并行 / false=串行)
use_threads = true
; 并发线程数 (api I/O 密集型, 建议 3-5)
threads = 5

[output]
; 结果保存目录
result_dir = output
